<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NAYRO VEX | ULTIMATE PRECISION</title>
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;900&family=Tajawal:wght@700&display=swap" rel="stylesheet">
    <style>
        :root { --neon: #008cff; --bg: #010409; --card: #0d1117; --border: #30363d; }
        body { background: var(--bg); color: #fff; margin: 0; font-family: 'Tajawal', sans-serif; height: 100vh; display: flex; flex-direction: column; overflow: hidden; }
        .header { height: 60px; background: var(--card); display: flex; align-items: center; padding: 0 20px; justify-content: space-between; border-bottom: 2px solid var(--neon); }
        .logo { font-family: 'Orbitron'; font-weight: 900; color: var(--neon); font-size: 1.4rem; }
        .search-box { display: flex; background: #000; border: 1px solid var(--border); border-radius: 5px; padding: 5px; width: 300px; }
        .search-box input { background: none; border: none; color: #fff; outline: none; width: 100%; padding-left: 10px; font-family: 'Orbitron'; }
        .search-box button { background: var(--neon); border: none; color: #fff; padding: 5px 15px; cursor: pointer; border-radius: 3px; font-weight: bold; }
        #chart-area { flex: 1; position: relative; }
        #radar { height: 35vh; background: var(--card); border-top: 1px solid var(--border); overflow-y: auto; padding: 15px; }
        .sig-card { background: #161b22; border: 1px solid var(--border); border-radius: 8px; padding: 15px; margin-bottom: 10px; display: flex; justify-content: space-between; align-items: center; border-right: 4px solid var(--neon); cursor: pointer; }
        .pat-tag { color: var(--neon); font-family: 'Orbitron'; font-size: 0.8rem; letter-spacing: 1px; }
        .tf-chip { background: var(--neon); color: #000; font-size: 10px; padding: 2px 6px; border-radius: 3px; font-weight: 900; margin-left: 10px; }
    </style>
</head>
<body>

<div class="header">
    <div class="logo">NAYRO VEX PRO</div>
    <div class="search-box">
        <input type="text" id="symIn" placeholder="BTCUSDT...">
        <button onclick="updateChart()">SEARCH</button>
    </div>
</div>

<div id="chart-area"><div id="tv_container" style="height: 100%;"></div></div>

<div id="radar">
    <div style="color: var(--neon); font-family: 'Orbitron'; font-size: 0.7rem; margin-bottom: 10px;">VALIDATED HARMONIC SIGNALS (6 PATTERNS)</div>
    <div id="list"></div>
</div>

<script src="https://s3.tradingview.com/tv.js"></script>
<script>
const Validator = {
    check(pts) {
        if (pts.length < 5) return null;
        const [X, A, B, C, D] = pts.map(p => p.v);
        if (X === A || B === C) return null; // حماية من النقاط المكررة

        const xa = Math.abs(A - X);
        const ab = Math.abs(B - A) / xa;
        const bc = Math.abs(C - B) / Math.abs(B - A);
        const ad = Math.abs(D - A) / xa;

        // دقة النماذج الستة (Tolerance 3%)
        if (this.near(ab, 0.618) && this.near(ad, 0.786)) return "GARTLEY";
        if (this.near(ab, 0.382, 0.5) && this.near(ad, 0.886)) return "BAT";
        if (this.near(ab, 0.786) && this.near(ad, 1.27, 1.618)) return "BUTTERFLY";
        if (this.near(ab, 0.382, 0.886) && this.near(ad, 1.618)) return "CRAB";
        if (this.near(bc, 1.27, 1.41) && ad <= 0.786) return "CYPHER";
        if (ad >= 0.886 && ad <= 1.13) return "SHARK";

        return null;
    },
    near(val, target, max = null) {
        const tol = 0.03;
        if (max) return val >= target - tol && val <= max + tol;
        return val >= target - tol && val <= target + tol;
    }
};

const Core = {
    async scanAll() {
        try {
            const pairs = await fetch('https://api.binance.com/api/v3/exchangeInfo').then(r => r.json());
            const usdtPairs = pairs.symbols.filter(s => s.quoteAsset === 'USDT' && s.status === 'TRADING').map(s => s.symbol);
            for (let i = 0; i < usdtPairs.length; i += 15) {
                const batch = usdtPairs.slice(i, i+15);
                await Promise.all(batch.map(s => this.analyze(s)));
                await new Promise(r => setTimeout(r, 600));
            }
        } catch(e) {}
    },

    async analyze(sym) {
        for (let tf of ['15m', '1h', '4h']) {
            try {
                const k = await fetch(`https://api.binance.com/api/v3/klines?symbol=${sym}&interval=${tf}&limit=100`).then(r => r.json());
                const closes = k.map(c => parseFloat(c[4]));
                const points = this.getZ(closes);
                const pattern = Validator.check(points);
                if (pattern) UI.render(sym, pattern, tf, closes[closes.length-1]);
            } catch(e) {}
        }
    },

    getZ(d) {
        let pts = [];
        // محرك البحث عن القمم والقيعان الحقيقية (Significant Swings)
        for (let i = 5; i < d.length - 5; i++) {
            let isMax = true, isMin = true;
            for (let j = 1; j <= 5; j++) {
                if (d[i] <= d[i-j] || d[i] <= d[i+j]) isMax = false;
                if (d[i] >= d[i-j] || d[i] >= d[i+j]) isMin = false;
            }
            if (isMax || isMin) pts.push({v: d[i]});
        }
        return pts.slice(-5);
    }
};

const UI = {
    render(sym, pat, tf, pr) {
        const list = document.getElementById('list');
        const id = `${sym}-${pat}-${tf}`;
        if (document.getElementById(id)) return;
        const el = document.createElement('div');
        el.id = id; el.className = 'sig-card';
        el.innerHTML = `<div><span class="tf-chip">${tf.toUpperCase()}</span><span style="font-family:'Orbitron'; margin-right:10px;">${sym}</span><div class="pat-tag">${pat}</div></div>
                        <div style="text-align:left;"><div style="font-family:'Orbitron';">$${pr.toFixed(pr < 1 ? 4 : 2)}</div><div style="font-size:9px; color:#555;">RATIO VERIFIED</div></div>`;
        el.onclick = () => this.loadChart(sym, tf);
        list.prepend(el);
    },
    loadChart(s, t) {
        const m = {'15m':'15','1h':'60','4h':'240'};
        new TradingView.widget({
            "autosize": true, "symbol": "BINANCE:"+s, "interval": m[t]||"60",
            "theme": "dark", "container_id": "tv_container", "locale": "ar",
            "studies": ["RSI@tv-basicstudies", "Volume@tv-basicstudies"]
        });
    }
};

function updateChart() {
    let s = document.getElementById('symIn').value.toUpperCase();
    if (s) {
        if (!s.endsWith('USDT')) s += 'USDT';
        UI.loadChart(s, '60');
    }
}

window.onload = () => { UI.loadChart('BTCUSDT', '60'); Core.scanAll(); setInterval(()=>Core.scanAll(), 300000); };
</script>
</body>
</html>
