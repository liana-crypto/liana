<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>LIANA | MILITARY RADAR</title>
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;900&family=Tajawal:wght@700&display=swap" rel="stylesheet">
    <style>
        :root { --army-green: #4b5320; --neon-green: #00ff41; --bg: #050505; --card: #0d0d0d; --border: #1a1a1a; }
        body { background: var(--bg); color: var(--neon-green); margin: 0; font-family: 'Tajawal', sans-serif; height: 100vh; display: flex; flex-direction: column; overflow: hidden; }
        
        .header { height: 50px; background: #000; display: flex; align-items: center; padding: 0 15px; justify-content: space-between; border-bottom: 2px solid var(--army-green); }
        .logo { font-family: 'Orbitron'; font-weight: 900; color: var(--neon-green); font-size: 1.2rem; text-shadow: 0 0 8px var(--neon-green); letter-spacing: 2px; }

        .pattern-selector { background: #000; padding: 8px; display: grid; grid-template-columns: repeat(3, 1fr); gap: 6px; border-bottom: 1px solid var(--army-green); }
        .p-btn { 
            background: #0a0a0a; border: 1px solid var(--army-green); color: var(--army-green); 
            padding: 8px; border-radius: 2px; cursor: pointer; font-family: 'Orbitron'; 
            font-size: 0.65rem; text-align: center; transition: 0.3s;
        }
        .p-btn.active { 
            background: var(--army-green); color: #000; font-weight: bold; 
            box-shadow: 0 0 12px var(--army-green); border-color: var(--neon-green);
        }

        #tv_container { flex: 1; width: 100%; filter: contrast(1.1); }

        #radar { 
            height: 32vh; background: #020202; border-top: 2px solid var(--army-green); 
            overflow-y: auto; padding: 10px; position: relative;
        }
        #radar::before { content: "LIANA TACTICAL SCANNER"; position: absolute; top: 2px; right: 10px; font-size: 8px; color: var(--army-green); }
        
        .sig-card { 
            background: rgba(75, 83, 32, 0.1); border: 1px solid var(--army-green); 
            padding: 10px; margin-bottom: 6px; display: flex; justify-content: space-between; 
            align-items: center; border-left: 4px solid var(--neon-green); cursor: pointer;
            animation: fadeIn 0.4s ease;
        }
        @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
        .sig-name { font-family: 'Orbitron'; font-size: 0.85rem; color: #fff; }
        .sig-pat { font-size: 0.7rem; color: var(--neon-green); letter-spacing: 1px; }
    </style>
</head>
<body>

<div class="header">
    <div class="logo">LIANA SYSTEM</div>
    <div style="font-size: 10px; color: var(--army-green);">TARGETING: HARMONIC PRECISION</div>
</div>

<div class="pattern-selector">
    <button class="p-btn" id="btn-GARTLEY" onclick="Engine.toggle('GARTLEY')">GARTLEY</button>
    <button class="p-btn" id="btn-BAT" onclick="Engine.toggle('BAT')">BAT</button>
    <button class="p-btn" id="btn-BUTTERFLY" onclick="Engine.toggle('BUTTERFLY')">BUTTERFLY</button>
    <button class="p-btn" id="btn-CRAB" onclick="Engine.toggle('CRAB')">CRAB</button>
    <button class="p-btn" id="btn-CYPHER" onclick="Engine.toggle('CYPHER')">CYPHER</button>
    <button class="p-btn" id="btn-SHARK" onclick="Engine.toggle('SHARK')">SHARK</button>
</div>

<div id="tv_container"></div>

<div id="radar">
    <div id="signals-box"></div>
</div>

<script src="https://s3.tradingview.com/tv.js"></script>
<script>
const Logic = {
    selectedPatterns: new Set(),
    check(pts) {
        if (pts.length < 5) return null;
        const [X, A, B, C, D] = pts.map(p => p.v);
        const xa = Math.abs(A - X), ab = Math.abs(B - A) / xa, bc = Math.abs(C - B) / Math.abs(B - A), ad = Math.abs(D - A) / xa;
        const tol = 0.02; // دقة 10000%

        if (this.near(ab, 0.618, tol) && this.near(ad, 0.786, tol)) return "GARTLEY";
        if (ab < 0.50 + tol && this.near(ad, 0.886, tol)) return "BAT";
        if (this.near(ab, 0.786, tol) && this.near(ad, 1.27, tol)) return "BUTTERFLY";
        if (ab <= 0.886 && this.near(ad, 1.618, tol)) return "CRAB";
        if (bc >= 1.27 && bc <= 1.41 && this.near(ad, 0.786, tol)) return "CYPHER";
        if (ad >= 0.886 - tol && ad <= 1.13 + tol) return "SHARK";
        return null;
    },
    near(v, t, e) { return v >= t - e && v <= t + e; }
};

const Engine = {
    isScanning: false,
    async toggle(pat) {
        const btn = document.getElementById(`btn-${pat}`);
        if (Logic.selectedPatterns.has(pat)) {
            Logic.selectedPatterns.delete(pat);
            btn.classList.remove('active');
        } else {
            Logic.selectedPatterns.add(pat);
            btn.classList.add('active');
            if (!this.isScanning) { this.isScanning = true; this.run(); }
        }
        document.getElementById('signals-box').innerHTML = ''; 
    },
    async run() {
        while (this.isScanning) {
            if (Logic.selectedPatterns.size === 0) { this.isScanning = false; break; }
            try {
                const info = await fetch('https://api.binance.com/api/v3/exchangeInfo').then(r => r.json());
                const symbols = info.symbols.filter(s => s.quoteAsset === 'USDT' && s.status === 'TRADING').map(s => s.symbol);
                for (let s of symbols) {
                    if (Logic.selectedPatterns.size === 0) break;
                    await this.scan(s);
                    await new Promise(r => setTimeout(r, 150));
                }
            } catch (e) {}
            await new Promise(r => setTimeout(r, 30000));
        }
    },
    async scan(s) {
        for (let tf of ['15m', '1h', '4h']) {
            try {
                const k = await fetch(`https://api.binance.com/api/v3/klines?symbol=${s}&interval=${tf}&limit=80`).then(r => r.json());
                const closes = k.map(c => parseFloat(c[4]));
                const pts = this.getZ(closes);
                const res = Logic.check(pts);
                if (res && Logic.selectedPatterns.has(res)) UI.add(s, res, tf, closes[closes.length-1]);
            } catch (e) {}
        }
    },
    getZ(d) {
        let pts = [];
        for (let i = 5; i < d.length - 5; i++) {
            let isMax = true, isMin = true;
            for (let j = 1; j <= 5; j++) {
                if (d[i] <= d[i-j] || d[i] <= d[i+j]) isMax = false;
                if (d[i] >= d[i-j] || d[i] >= d[i+j]) isMin = false;
            }
            if (isMax || isMin) pts.push({v: d[i]});
        }
        return pts.slice(-5);
    }
};

const UI = {
    add(sym, pat, tf, pr) {
        const box = document.getElementById('signals-box');
        const id = `${sym}-${pat}-${tf}`;
        if (document.getElementById(id)) return;
        const el = document.createElement('div');
        el.id = id; el.className = 'sig-card';
        el.innerHTML = `<div><div class="sig-name">${sym}</div><div class="sig-pat">${pat} - ${tf}</div></div>
                        <div style="font-family:Orbitron; font-size:0.8rem;">$${pr.toFixed(2)}</div>`;
        el.onclick = () => this.loadChart(sym, tf);
        box.prepend(el);
    },
    loadChart(s, t) {
        new TradingView.widget({
            "autosize": true, "symbol": "BINANCE:"+s, "interval": t === '15m' ? '15' : (t === '1h' ? '60' : '240'),
            "theme": "dark", "container_id": "tv_container", "locale": "ar", "gridColor": "rgba(75, 83, 32, 0.1)"
        });
    }
};
window.onload = () => UI.loadChart('BTCUSDT', '1h');
</script>
</body>
</html>
