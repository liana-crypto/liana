<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>LIANA COMMANDER</title>
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;900&family=Tajawal:wght@700&display=swap" rel="stylesheet">
    <style>
        :root { --army: #4b5320; --neon: #00ff41; --bg: #050505; }
        body { background: var(--bg); color: var(--neon); margin: 0; font-family: 'Tajawal', sans-serif; height: 100vh; display: flex; flex-direction: column; overflow: hidden; }
        
        .header { height: 45px; background: #000; display: flex; align-items: center; padding: 0 15px; justify-content: space-between; border-bottom: 2px solid var(--army); }
        .logo { font-family: 'Orbitron'; font-weight: 900; color: var(--neon); font-size: 1.1rem; text-shadow: 0 0 10px var(--neon); }

        .pattern-grid { background: #000; padding: 10px; display: grid; grid-template-columns: repeat(3, 1fr); gap: 8px; border-bottom: 2px solid var(--army); }
        .p-btn { 
            background: #0d0d0d; border: 1px solid var(--army); color: var(--army); 
            padding: 12px; border-radius: 4px; cursor: pointer; font-family: 'Orbitron'; 
            font-size: 0.65rem; transition: 0.3s; text-align: center; font-weight: bold;
        }
        .p-btn.active { background: var(--army); color: #000; box-shadow: 0 0 15px var(--neon); border-color: var(--neon); }

        #tv_container { flex: 1; width: 100%; border-bottom: 1px solid var(--army); }

        #radar { height: 35vh; background: #020202; overflow-y: auto; padding: 10px; position: relative; }
        .sig-item { 
            background: rgba(75, 83, 32, 0.1); border: 1px solid var(--army); 
            padding: 12px; margin-bottom: 8px; display: flex; justify-content: space-between; 
            align-items: center; border-left: 5px solid var(--neon); cursor: pointer;
            animation: slideIn 0.35s cubic-bezier(0.175, 0.885, 0.32, 1.275) both;
        }
        @keyframes slideIn { 0% { transform: scale(0.8); opacity: 0; } 100% { transform: scale(1); opacity: 1; } }
        .coin-txt { font-family: 'Orbitron'; font-size: 0.95rem; color: #fff; }
        .label { font-size: 0.7rem; color: var(--neon); font-weight: bold; display: block; letter-spacing: 1px; }
    </style>
</head>
<body>

<div class="header">
    <div class="logo">LIANA COMMAND</div>
    <div id="status" style="font-size: 0.6rem; color: var(--army); font-family: 'Orbitron';">SYSTEM: ONLINE</div>
</div>

<div class="pattern-grid">
    <button class="p-btn" id="btn-GARTLEY" onclick="Engine.toggle('GARTLEY')">GARTLEY</button>
    <button class="p-btn" id="btn-BAT" onclick="Engine.toggle('BAT')">BAT</button>
    <button class="p-btn" id="btn-BUTTERFLY" onclick="Engine.toggle('BUTTERFLY')">BUTTERFLY</button>
    <button class="p-btn" id="btn-CRAB" onclick="Engine.toggle('CRAB')">CRAB</button>
    <button class="p-btn" id="btn-CYPHER" onclick="Engine.toggle('CYPHER')">CYPHER</button>
    <button class="p-btn" id="btn-SHARK" onclick="Engine.toggle('SHARK')">SHARK</button>
</div>

<div id="tv_container"></div>
<div id="radar"><div id="signals-box"></div></div>

<script src="https://s3.tradingview.com/tv.js"></script>
<script>
const Logic = {
    selectedPatterns: new Set(),
    check(pts) {
        if (pts.length < 5) return null;
        const [X, A, B, C, D] = pts.map(p => p.v);
        const xa = Math.abs(A-X), ab = Math.abs(B-A)/xa, bc = Math.abs(C-B)/Math.abs(B-A), ad = Math.abs(D-A)/xa;
        const tol = 0.08; // مرونة 8% لضمان عدم ضياع الفرص

        if (this.near(ab, 0.618, tol) && this.near(ad, 0.786, tol)) return "GARTLEY";
        if (this.near(ab, 0.447, 0.15) && this.near(ad, 0.886, tol)) return "BAT";
        if (this.near(ab, 0.786, tol) && this.near(ad, 1.27, tol)) return "BUTTERFLY";
        if (this.near(ab, 0.886, 0.15) && this.near(ad, 1.618, tol)) return "CRAB";
        if (bc >= 1.27 && this.near(ad, 0.786, 0.12)) return "CYPHER";
        if (ad >= 0.886 && ad <= 1.13) return "SHARK";
        return null;
    },
    near(v, t, e) { return v >= t - e && v <= t + e; }
};

const Engine = {
    isScanning: false,
    async toggle(pat) {
        const btn = document.getElementById(`btn-${pat}`);
        if (Logic.selectedPatterns.has(pat)) {
            Logic.selectedPatterns.delete(pat);
            btn.classList.remove('active');
        } else {
            Logic.selectedPatterns.add(pat);
            btn.classList.add('active');
            if (!this.isScanning) { this.isScanning = true; this.run(); }
        }
        document.getElementById('signals-box').innerHTML = ''; 
    },
    async run() {
        while (this.isScanning) {
            if (Logic.selectedPatterns.size === 0) { this.isScanning = false; break; }
            document.getElementById('status').innerText = "RADAR: SCANNING... 🎯";
            try {
                const r = await fetch('https://api.binance.com/api/v3/exchangeInfo').then(res => res.json());
                const symbols = r.symbols.filter(s => s.quoteAsset === 'USDT' && s.status === 'TRADING').map(s => s.symbol).slice(0, 300);
                for (let s of symbols) {
                    if (Logic.selectedPatterns.size === 0) break;
                    await this.analyze(s);
                    await new Promise(res => setTimeout(res, 40)); // مسح فائق السرعة
                }
            } catch (e) {}
            await new Promise(res => setTimeout(res, 5000));
        }
    },
    async analyze(s) {
        const tfs = ['15m', '1h', '4h'];
        for (let tf of tfs) {
            try {
                const k = await fetch(`https://api.binance.com/api/v3/klines?symbol=${s}&interval=${tf}&limit=80`).then(res => res.json());
                const prices = k.map(c => parseFloat(c[4]));
                const pts = this.getZ(prices);
                const result = Logic.check(pts);
                if (result && Logic.selectedPatterns.has(result)) UI.add(s, result, tf, prices[prices.length-1]);
            } catch (e) {}
        }
    },
    getZ(d) {
        let pts = [];
        for (let i = 2; i < d.length - 2; i++) {
            if ((d[i] > d[i-1] && d[i] > d[i+1]) || (d[i] < d[i-1] && d[i] < d[i+1])) pts.push({v: d[i]});
        }
        return pts.slice(-5);
    }
};

const UI = {
    add(sym, pat, tf, pr) {
        const box = document.getElementById('signals-box');
        if (document.getElementById(`${sym}-${pat}-${tf}`)) return;
        const el = document.createElement('div');
        el.id = `${sym}-${pat}-${tf}`; el.className = 'sig-item';
        el.innerHTML = `<div><span class="coin-txt">${sym} <small style="color:var(--army)">[${tf}]</small></span><span class="label">${pat} LOCKED</span></div>
                        <div style="font-family:Orbitron; font-weight:bold;">$${pr.toFixed(pr < 1 ? 4 : 2)}</div>`;
        el.onclick = () => this.loadChart(sym, tf);
        box.prepend(el);
    },
    loadChart(s, t) {
        new TradingView.widget({
            "autosize": true, "symbol": "BINANCE:"+s, "interval": t==='15m'?'15':(t==='1h'?'60':'240'),
            "theme": "dark", "container_id": "tv_container", "locale": "ar", "style": "1"
        });
    }
};
window.onload = () => UI.loadChart('BTCUSDT', '1h');
</script>
</body>
</html>
