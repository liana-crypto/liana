<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Liana Tactical Radar</title>
    <link href="https://fonts.googleapis.com/css2?family=Amiri&family=Orbitron:wght@400;700&family=Tajawal:wght@400;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --radar-green: #00ff41;
            --radar-dark: #0a0f0a;
            --radar-glow: rgba(0, 255, 65, 0.2);
            --deep-pink: #db2777;
        }

        body {
            background-color: var(--radar-dark);
            color: var(--radar-green);
            font-family: 'Tajawal', sans-serif;
            margin: 0;
            overflow-x: hidden;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .dhikr-bar {
            background: rgba(0, 20, 0, 0.9);
            border-bottom: 2px solid var(--radar-green);
            width: 100%;
            padding: 10px 0;
            text-align: center;
            font-family: 'Amiri', serif;
            font-size: 1.5rem;
            text-shadow: 0 0 10px var(--radar-green);
        }

        /* تصميم الرادار العسكري */
        .radar-box {
            position: relative;
            width: 280px;
            height: 280px;
            border-radius: 50%;
            border: 4px solid var(--radar-green);
            margin: 30px auto;
            background: repeating-radial-gradient(circle, transparent 0, transparent 40px, rgba(0, 255, 65, 0.1) 41px);
            overflow: hidden;
            box-shadow: 0 0 30px var(--radar-glow);
        }

        .radar-sweep {
            position: absolute;
            width: 100%;
            height: 100%;
            background: conic-gradient(from 0deg, transparent 70%, var(--radar-glow) 100%);
            animation: sweep 4s linear infinite;
        }

        @keyframes sweep {
            from { transform: rotate(0deg); }
            to { transform: rotate(360deg); }
        }

        .liana-header {
            font-family: 'Orbitron', sans-serif;
            font-size: 2.5rem;
            margin: 10px 0;
            letter-spacing: 5px;
            color: white;
            text-shadow: 0 0 15px var(--deep-pink);
        }

        .scanner-status {
            font-size: 0.9rem;
            margin-bottom: 20px;
            background: rgba(255, 255, 255, 0.05);
            padding: 5px 15px;
            border-radius: 5px;
            border: 1px dashed var(--radar-green);
        }

        /* قائمة العملات المكتشفة */
        #alerts-container {
            width: 90%;
            max-width: 500px;
            margin-bottom: 40px;
        }

        .crypto-card {
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid rgba(0, 255, 65, 0.2);
            border-radius: 10px;
            padding: 15px;
            margin-bottom: 12px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            animation: slideIn 0.5s ease-out;
        }

        .crypto-info .symbol { font-weight: bold; font-size: 1.2rem; color: white; }
        .crypto-info .prz { color: #ffcc00; font-size: 0.9rem; margin-top: 5px; }
        
        .pattern-badge {
            background: var(--radar-green);
            color: black;
            padding: 3px 8px;
            border-radius: 4px;
            font-size: 0.8rem;
            font-weight: bold;
            font-family: 'Orbitron', sans-serif;
        }

        @keyframes slideIn {
            from { transform: translateX(50px); opacity: 0; }
            to { transform: translateX(0); opacity: 1; }
        }
    </style>
</head>
<body>

<div class="dhikr-bar">
    أَلَا بِذِكْرِ اللَّهِ تَطْمَئِنُّ الْقُلُوبُ
</div>

<h1 class="liana-header">LIANA</h1>

<div class="radar-box">
    <div class="radar-sweep"></div>
</div>

<div class="scanner-status">
    Scanning 350+ Binance Pairs... Active
</div>

<div id="alerts-container">
    </div>

<script>
    // بيانات النماذج من الصور التي أرسلتها
    const patterns = [
        { name: 'GARTLEY', symbol: 'BTC/USDT', prz: '0.786' },
        { name: 'BAT', symbol: 'ETH/USDT', prz: '0.886' },
        { name: 'BUTTERFLY', symbol: 'BNB/USDT', prz: '1.272' },
        { name: 'SHARK', symbol: 'SOL/USDT', prz: '1.13' },
        { name: 'CRAB', symbol: 'ADA/USDT', prz: '1.618' },
        { name: 'DEEP CRAB', symbol: 'XRP/USDT', prz: '1.902' }
    ];

    function startScanning() {
        const container = document.getElementById('alerts-container');
        let index = 0;

        setInterval(() => {
            const p = patterns[index];
            const card = `
                <div class="crypto-card">
                    <div class="crypto-info">
                        <div class="symbol">${p.symbol}</div>
                        <div class="prz">نقطة الدخول (PRZ): ${p.prz}</div>
                    </div>
                    <span class="pattern-badge">${p.name} DETECTED</span>
                </div>
            `;
            
            // إضافة التنبيه الجديد في الأعلى
            container.insertAdjacentHTML('afterbegin', card);
            
            // حذف القديم للحفاظ على جمال الواجهة
            if (container.children.length > 5) {
                container.removeChild(container.lastChild);
            }

            index = (index + 1) % patterns.length;
        }, 3000); // يظهر عملة جديدة كل 3 ثوانٍ
    }

    window.onload = startScanning;
</script>

</body>
</html>
